# ── App ─────────────────────────────────────────────
PORT=5050
JWT_SECRET=set-a-long-random-secret
# Public base URL of the deployed app (used to build the GitHub OAuth callback + redirects).
# Locally this can be http://localhost:5050
APP_URL=http://localhost:5050

# ── GitHub sign-in (OAuth App) ──────────────────────
# Create at github.com → Settings → Developer settings → OAuth Apps.
# Authorization callback URL must be:  <APP_URL>/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
# GitHub username that gets the admin panel.
ADMIN_GITHUB_LOGIN=Yuukonori

# ── AI Helper (Google Gemini) ───────────────────────
# Create a key at aistudio.google.com → Get API key. Without it the AI Helper panel still renders,
# but every request returns "not configured".
GEMINI_API_KEY=your-gemini-api-key

# MULTIPLE KEYS (optional). One agent turn is 7 sequential model calls, which can trip a free-tier
# per-minute limit on its own. Give the server more than one key and it round-robins between them,
# failing over to the next when one is rate-limited or out of quota. Two equivalent ways — use either:
#
#   GEMINI_API_KEY=key-one,key-two,key-three        # comma-separated on one line
#
#   GEMINI_API_KEY_1=key-one                        # or one per line (easier to read/comment out)
#   GEMINI_API_KEY_2=key-two
#   GEMINI_API_KEY_3=key-three
#
# Both forms can be mixed; duplicates are ignored. Up to GEMINI_API_KEY_20.
#
# CAVEAT — read before relying on this: Gemini's free quota is metered per Google Cloud *project*,
# not per key. Several keys minted in the SAME project all draw from ONE bucket, so rotating them
# gains you nothing. Extra keys only add headroom when each belongs to a different project/account.

# effort -> model. Optional: the defaults in server/geminis.js are used when these are unset.
# Verified reachable on these keys. Note the models differ in their thinking DEFAULT: gemini-3.5-flash
# thinks unless told otherwise (~639 thought tokens on a trivial prompt), gemini-3.1-flash-lite does not.
# GEMINI_MODEL_LOW=gemini-3.1-flash-lite
# GEMINI_MODEL_MEDIUM=gemini-3.5-flash
# GEMINI_MODEL_HIGH=gemini-3.5-flash

# Per-request upstream timeout (ms). Thinking models need more than a plain completion.
# GEMINI_TIMEOUT_MS=60000

# Google Search grounding for the agent's style-research stage. Set false if that quota runs out —
# the stage degrades to model knowledge and the build still proceeds.
# GEMINI_ENABLE_SEARCH=true

# ── AI Helper fallback provider (Groq) ──────────────
# Optional but recommended. When every Gemini key is rate-limited or Gemini is down, the server
# retries the same request on Groq instead of failing the turn. These are the models the AI Helper's
# stage prompts were originally tuned against (under n8n), so a failover still meets the stage
# contracts rather than degrading quality.
# Keys from console.groq.com. Same two formats as above; GROQ_API_KEY_1..20.
GROQ_API_KEY_1=your-groq-api-key
# GROQ_API_KEY_2=...

# Groq's free tier meters per ACCOUNT (Gemini's is per project) — several keys from one Groq account
# share one bucket, so extra keys only add headroom across separate accounts.

# GROQ_MODEL_LOW=llama-3.1-8b-instant
# GROQ_MODEL_MEDIUM=llama-3.3-70b-versatile
# GROQ_MODEL_HIGH=llama-3.3-70b-versatile
# GROQ_TIMEOUT_MS=60000

# Which provider is tried first. Default: gemini,groq. Flip to groq,gemini to make Groq primary
# (handy while Gemini quota is dry). A provider with no keys is skipped automatically.
# AI_PROVIDER_ORDER=gemini,groq

# ── Database ────────────────────────────────────────
# Option A (recommended for Render/hosted): one connection string. Takes precedence over DB_* below.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Option B (local / self-managed): discrete vars.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_NAME=postgres

# TLS to the database. Leave false for local Postgres; set true for managed Postgres (e.g. Render).
# When DATABASE_URL is set, SSL defaults to ON unless you explicitly set DB_SSL=false.
DB_SSL=false
