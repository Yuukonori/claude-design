# ── App ─────────────────────────────────────────────
PORT=5050
JWT_SECRET=set-a-long-random-secret
# Public base URL of the deployed app (used to build the GitHub OAuth callback + redirects).
# Locally this can be http://localhost:5050
APP_URL=http://localhost:5050

# ── GitHub sign-in (OAuth App) ──────────────────────
# Create at github.com → Settings → Developer settings → OAuth Apps.
# Authorization callback URL must be:  <APP_URL>/api/auth/github/callback
GITHUB_CLIENT_ID=your-github-oauth-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-client-secret
# GitHub username that gets the admin panel.
ADMIN_GITHUB_LOGIN=Yuukonori

# ── Database ────────────────────────────────────────
# Option A (recommended for Render/hosted): one connection string. Takes precedence over DB_* below.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Option B (local / self-managed): discrete vars.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-postgres-password
DB_NAME=postgres

# TLS to the database. Leave false for local Postgres; set true for managed Postgres (e.g. Render).
# When DATABASE_URL is set, SSL defaults to ON unless you explicitly set DB_SSL=false.
DB_SSL=false
