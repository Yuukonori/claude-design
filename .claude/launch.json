{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5050
    },
    {
      "name": "app",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "autoPort": true
    },
    {
      "name": "static",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "static"],
      "port": 3000
    },
    {
      "name": "preview",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "."],
      "autoPort": true
    }
  ]
}
